T = int(input())

for _ in range(T):
    s = input()
    
    if len(s) < 10:
        print("NO")
        continue
    
    middle = s[1:-1]  # strictly inside part
    
    if (any(c.islower() for c in s) and
        any(c.isupper() for c in middle) and
        any(c.isdigit() for c in middle) and
        any(c in '@#%&?' for c in middle)):
        print("YES")
    else:
        print("NO")
